# ===========================================
# .clineignore - Files/directories Cline should ignore
# ===========================================

# Manually Added
PRD.md


# Dependencies
node_modules/
.pnp.js
.pnp/
.yarn/

# Build outputs
.next/
out/
build/
dist/

# Lock files (large, auto-generated)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Cache and temp files
.cache/
*.tsbuildinfo
coverage/
.turbo/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env
.env.*
.env*.local

# Binary/Asset files
*.woff
*.woff2
*.ttf
*.eot
*.ico
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.webp
*.mp4
*.webm
*.mp3
*.wav

# System files
.DS_Store
Thumbs.db
*.pem

# Git
.git/

# Vercel
.vercel/

# Auto-generated TypeScript
next-env.d.ts

# IDE specific (if any)
.idea/
*.swp
*.swo
